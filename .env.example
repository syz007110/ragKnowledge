# 复制为项目根目录的 .env 后由 Docker Compose 自动加载（用于 ${VAR} 插值）。
# 命令：cp .env.example .env  &&  编辑 .env 填入生产级密钥
# 勿将 .env 提交到 Git。

# -----------------------------------------------------------------------------
# PostgreSQL（与 backend/.env 中 PG_* 保持一致）
# -----------------------------------------------------------------------------
POSTGRES_DB=logtool_knowledge
POSTGRES_USER=logtool
POSTGRES_PASSWORD=changeme_postgres
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Elasticsearch（与 backend/.env 中 ES_* 保持一致）
# -----------------------------------------------------------------------------
ELASTIC_USERNAME=elastic
ELASTIC_PASSWORD=changeme_elastic
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_TRANSPORT_PORT=9300
# 可选：覆盖 JVM 堆，例如 "-Xms2g -Xmx2g"
# ES_JAVA_OPTS=-Xms1g -Xmx1g

# -----------------------------------------------------------------------------
# MinIO（与 backend/.env 中 KB_OBJECT_STORAGE_* 保持一致）
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=rag_flow
MINIO_ROOT_PASSWORD=changeme_minio
MINIO_BUCKET=logtoolkb
MINIO_API_PORT=19000
MINIO_CONSOLE_PORT=19001

# -----------------------------------------------------------------------------
# Kibana（与 Elasticsearch 配套）
# KIBANA_ENCRYPTION_KEY：openssl rand -hex 32 自生成
# KIBANA_ES_SERVICE_ACCOUNT_TOKEN：向 ES 申请，见 BUILD.md「2.1 Kibana 相关变量填写说明」
# 更换 ELASTIC_PASSWORD 或清空 data/elasticsearch 后通常需重新申请 token
# -----------------------------------------------------------------------------
KIBANA_ES_SERVICE_ACCOUNT_TOKEN=AAEAAWVsYXN0aWMva2liYW5hL21rbm93bGVkZ2Uta2liYW5hLXRva2VuOjBWRTRrdUUzVHEyaDhTc0Eycm9DMEE
KIBANA_ENCRYPTION_KEY=mknowledge-kibana-encryption-key-32c
KIBANA_PORT=5601

# -----------------------------------------------------------------------------
# Redis / Qdrant 端口（一般无需改）
# -----------------------------------------------------------------------------
REDIS_PORT=6379
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# -----------------------------------------------------------------------------
# GPU 文档服务镜像构建（见 document-service/Dockerfile.gpu；与 NVIDIA 驱动/CUDA 对齐）
# PADDLE_WHEEL_INDEX=cu126
# apt 卡在 deb.debian.org 时（国内常见）：取消下一行注释，再 build
DEBIAN_APT_MIRROR_HOST=mirrors.aliyun.com
# pip 走官方 PyPI 失败（如 pypdf “from versions: none”）时覆盖索引；海外常用 https://pypi.org/simple
# PIP_INDEX_URL=https://pypi.org/simple
# -----------------------------------------------------------------------------
# 文档服务（与 backend/.env 中 KB_DOCUMENT_SERVICE_API_KEY 一致；可留空关闭校验）
# -----------------------------------------------------------------------------
KB_DOCUMENT_SERVICE_API_KEY=
DOCUMENT_SERVICE_PORT=8002
DOCUMENT_SERVICE_GPU_PORT=8003

# -----------------------------------------------------------------------------
# OnlyOffice（与 backend/.env 中 ONLYOFFICE_JWT_SECRET 一致）
# 生成示例：openssl rand -base64 48
# -----------------------------------------------------------------------------
ONLYOFFICE_DS_JWT_ENABLED=true
ONLYOFFICE_JWT_SECRET=onlyoffice_jwt_change_me
ONLYOFFICE_PORT=18080
