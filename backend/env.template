NODE_ENV=development
PORT=3301

# database (PostgreSQL for local knowledge base)
DB_DIALECT=postgres
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DATABASE=logtool_knowledge
PG_USER=postgres
PG_PASSWORD=your_password

# jwt config should match logtool
JWT_SECRET=replace_with_same_secret_as_logtool
LOGTOOL_API_BASE_URL=http://your-logtool-host:3000
LOGTOOL_API_TIMEOUT_MS=15000

# redis for queue
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# kb local file storage
KB_LOCAL_DIR=./uploads/kb
KB_MAX_FILES=5
KB_MAX_SIZE=20971520
KB_ALLOWED_MIMES=application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/msword,text/plain,text/markdown,application/octet-stream

# cluster
API_WORKER_PROCESSES=2
QUEUE_WORKER_PROCESSES=1
CLUSTER_RESTART_DELAY_MS=1000

# queue tuning (same style as logtool)
KB_QUEUE_CONCURRENCY=2
QUEUE_MAX_ATTEMPTS=3
QUEUE_BACKOFF_DELAY=2000
QUEUE_TIMEOUT_MS=600000
KB_QUEUE_TIMEOUT_MS=600000

# Elasticsearch sync
ENABLE_ES_SYNC=true
ES_BASE_URL=http://127.0.0.1:9200
ES_INDEX_NAME=kb_chunks
ES_USERNAME=
ES_PASSWORD=
ES_TIMEOUT_MS=20000

# RAGFlow sync
ENABLE_RAGFLOW_SYNC=true
RAGFLOW_BASE_URL=http://127.0.0.1:9380
RAGFLOW_API_KEY=
RAGFLOW_DATASET_ID=
RAGFLOW_DATASET_PERMISSION=me
RAGFLOW_DATASET_CHUNK_METHOD=manual
