NODE_ENV=development
PORT=3301

# database (PostgreSQL for local knowledge base)
DB_DIALECT=postgres
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DATABASE=logtool_knowledge
PG_USER=postgres
PG_PASSWORD=your_password

# jwt config should match logtool
JWT_SECRET=replace_with_same_secret_as_logtool

# OnlyOffice Document Server（与 docker-compose 中 onlyoffice 服务的 JWT_SECRET 必须相同）
# 若密钥只在 backend/.env：启动 onlyoffice 时用
#   docker compose --env-file ./backend/.env up -d onlyoffice
# 或在项目根目录（与 docker-compose.yml 同级）建 .env，写入与这里相同的 ONLYOFFICE_JWT_SECRET（Compose 会自动读根 .env 做插值）。
ONLYOFFICE_DOCUMENT_SERVER_URL=http://localhost:18080
ONLYOFFICE_INTEGRATION_BASE_URL=http://host.docker.internal:3301
ONLYOFFICE_JWT_SECRET=replace_with_same_secret_as_compose_onlyoffice
LOGTOOL_API_BASE_URL=http://your-logtool-host:3000
LOGTOOL_API_TIMEOUT_MS=15000

# redis for queue
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# kb local file storage
KB_LOCAL_DIR=./uploads/kb
KB_MAX_FILES=5
KB_MAX_SIZE=20971520
KB_ALLOWED_MIMES=application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/msword,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel,text/plain,text/markdown,application/octet-stream

# cluster
API_WORKER_PROCESSES=2
QUEUE_WORKER_PROCESSES=1
CLUSTER_RESTART_DELAY_MS=1000

# queue tuning (same style as logtool)
KB_QUEUE_CONCURRENCY=2
QUEUE_MAX_ATTEMPTS=3
QUEUE_BACKOFF_DELAY=2000
QUEUE_TIMEOUT_MS=1800000
KB_INGEST_QUEUE_TIMEOUT_MS=1800000
KB_QUEUE_TIMEOUT_MS=1800000

# object storage (MinIO/S3)
KB_OBJECT_STORAGE_ENABLED=true
KB_OBJECT_STORAGE_ENDPOINT=http://127.0.0.1:19000
KB_OBJECT_STORAGE_REGION=us-east-1
KB_OBJECT_STORAGE_BUCKET=logtoolkb
KB_OBJECT_STORAGE_ACCESS_KEY=rag_flow
KB_OBJECT_STORAGE_SECRET_KEY=infini_rag_flow
KB_OBJECT_STORAGE_FORCE_PATH_STYLE=true

# Elasticsearch sync
ENABLE_ES_SYNC=true
ES_BASE_URL=http://127.0.0.1:9200
ES_INDEX_NAME=kb_chunks
ES_USERNAME=elastic
ES_PASSWORD=replace_with_local_es_password
ES_TIMEOUT_MS=20000

# Vector sync (Qdrant + embedding API)
# Enable both Qdrant and embedding for semantic retrieval.
ENABLE_QDRANT_SYNC=true
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=kb_chunks
QDRANT_DISTANCE=Cosine
QDRANT_TIMEOUT_MS=30000
KB_VECTOR_SYNC_CONCURRENCY=2
ENABLE_EMBEDDING=true
EMBEDDING_BASE_URL=https://your-embedding-endpoint/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072
EMBEDDING_TIMEOUT_MS=30000
EMBEDDING_BATCH_SIZE=16

# 检索测试弹窗「生成」：与 EMBEDDING_BASE_URL / EMBEDDING_API_KEY 同一 OpenAI 兼容网关，单独指定聊天模型
# system / user 提示词与 temperature：src/config/retrievalTestChatPrompts.json（retrievalTestGenerate）
# 外部检索 API：POST /api/kb/retrieval/search 请求体可带 generate:true（与弹窗相同：强制 TopK=5 + 返回 generation）
KB_RETRIEVAL_TEST_CHAT_MODEL=gpt-4o-mini
# KB_RETRIEVAL_TEST_CHAT_TIMEOUT_MS=60000
